% ─── Типографика ─────────────────────────────────────────────────────────────

\setstretch{1.3}
\setlength{\parindent}{1.25em}
\setlength{\parskip}{0.4ex plus 0.2ex minus 0.1ex}

% ─── Титульная страница ───────────────────────────────────────────────────────

\newcommand{\maketitlepage}{%
    \begin{titlepage}
        \newgeometry{top=3cm, bottom=3cm, left=3cm, right=3cm}
        \begin{center}
            {\small\bfseries\institution}%
            \ifx\schoolname\empty\else\\[0.2em]{\small\bfseries\schoolname}\fi
        \end{center}
        \vspace{1.5cm}
        \begin{center}
            \includegraphics[height=3cm]{island.png}
        \end{center}
        \vspace{2cm}
        \begin{center}
            {\addfontfeature{LetterSpace=15}\large\bfseries\MakeUppercase{\coursename}}

            \vspace{1.5em}
            {\normalsize\color{secondary}\coursesubtitle}

            \vspace{2em}
            {\small Экзаменатор:\enspace\textit{\teachername}}
        \end{center}
        \vspace{2em}
        \ifx\authorlist\empty\else
        \begin{flushright}
            \small
            {\color{secondary}Авторы:}\enspace{\color{accent}\authorlist}
        \end{flushright}
        \fi
        \vfill
        \begin{center}
            {\small\color{secondary}\semester}
        \end{center}
        \restoregeometry
    \end{titlepage}
}

\newcommand{\toclink}{\hyperlink{toc}{Назад к содержанию}}

% ─── Колонтитулы ─────────────────────────────────────────────────────────────

\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\small\color{secondary}\coursename}
\fancyhead[R]{\small\color{accent}\toclink}
\fancyfoot[L]{\small\color{secondary}ВШПИ МФТИ, \semester}
\fancyfoot[R]{\small\color{secondary}\thepage}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0.4pt}
\renewcommand{\headrule}{{\color{rule}\hrule width\headwidth height\headrulewidth}}
\renewcommand{\footrule}{{\color{rule}\hrule width\headwidth height\footrulewidth}}

\fancypagestyle{plain}{%
    \fancyhf{}
    \fancyfoot[L]{\small\color{secondary}ВШПИ МФТИ, \semester}
    \fancyfoot[R]{\small\color{secondary}\thepage}
    \renewcommand{\headrulewidth}{0pt}
    \renewcommand{\footrulewidth}{0.4pt}
    \renewcommand{\footrule}{{\color{rule}\hrule width\headwidth height\footrulewidth}}
}

% ─── Заголовки секций ─────────────────────────────────────────────────────────

\titleformat{\section}{\large\bfseries\color{primary}}{\thesection.}{0.5em}{}
\titleformat{\subsection}{\normalsize\bfseries\color{primary}}{\thesubsection.}{0.5em}{}
\titleformat{\subsubsection}{\normalsize\itshape\color{primary}}{\thesubsubsection.}{0.5em}{}

\titlespacing*{\section}{0pt}{2ex plus 0.5ex}{1ex plus 0.2ex}
\titlespacing*{\subsection}{0pt}{1.5ex plus 0.3ex}{0.8ex plus 0.1ex}
\titlespacing*{\subsubsection}{0pt}{1ex plus 0.2ex}{0.5ex plus 0.1ex}

% ─── Билет ───────────────────────────────────────────────────────────────────

\newcounter{ticketnum}
\newcounter{questionnum}

\newcommand{\ticket}[2]{%
    \setcounter{ticketnum}{#1}%
    \setcounter{section}{0}%
    \setcounter{questionnum}{0}%
    \newpage
    \phantomsection
    \addcontentsline{toc}{section}{Билет №\,#1%
        \ifx\relax#2\relax\else:\enspace#2\fi}%
    \vspace*{1em}%
    \noindent\rule{\textwidth}{0.8pt}\par
    \vspace{0.8em}%
    \begin{center}
        {\Large \bfseries БИЛЕТ №\,#1}%
        \ifx\relax#2\relax\else\\[0.5em]%
            {\normalsize\normalfont\itshape #2}\fi
    \end{center}
    \vspace{0.2em}%
    \noindent\rule{\textwidth}{0.8pt}\par
    \vspace{2em}%
}

\newcommand{\question}[1]{%
    \stepcounter{questionnum}%
    \subsection*{\arabic{questionnum}.\enspace #1}%
    \addcontentsline{toc}{subsection}{\arabic{questionnum}.\enspace #1}%
}

% ─── Оглавление ──────────────────────────────────────────────────────────────

\renewcommand{\cfttoctitlefont}{\large\bfseries}
\renewcommand{\cftaftertoctitle}{\par\noindent{\color{rule}\rule{\textwidth}{0.5pt}}\vspace{0.5em}}
\renewcommand{\cftsecfont}{\normalfont}
\renewcommand{\cftsecpagefont}{\normalfont}
\renewcommand{\cftsecleader}{\cftdotfill{\cftsecdotsep}}
\renewcommand{\cftsecdotsep}{\cftdotsep}

% ─── Списки ──────────────────────────────────────────────────────────────────

\setlist{topsep=0.3ex, itemsep=0.2ex, parsep=0.1ex, leftmargin=1.5em}
\setlist[itemize,1]{label={\small\textbullet}}
\setlist[itemize,2]{label={\small--}}
\setlist[enumerate,1]{label={\arabic*.}}
\setlist[enumerate,2]{label={\alph*)}}

% ─── Теоремы ─────────────────────────────────────────────────────────────────

\theoremstyle{plain}
\newtheorem{theorem}{Теорема}[section]
\newtheorem{lemma}[theorem]{Лемма}
\newtheorem{proposition}[theorem]{Утверждение}
\newtheorem{corollary}[theorem]{Следствие}

\theoremstyle{definition}
\newtheorem{example}{Пример}[section]

\theoremstyle{remark}
\newtheorem*{remark}{Замечание}
\newtheorem*{note}{Примечание}

\renewcommand{\qedsymbol}{$\square$}

% ─── tcolorbox-окружения ─────────────────────────────────────────────────────

\newtcolorbox{thmbox}{
    breakable,
    colback=lightgray, colframe=rule, boxrule=0.5pt, arc=0pt,
    left=0.8em, right=0.8em, top=0.6em, bottom=0.6em, boxsep=0pt,
    before skip=0.8em, after skip=0.8em
}

\newtcolorbox{defbox}{
    breakable,
    colback=white, colframe=rule, boxrule=0.5pt, arc=0pt,
    left=0.8em, right=0.8em, top=0.6em, bottom=0.6em, boxsep=0pt,
    before skip=0.8em, after skip=0.8em,
    borderline west={2pt}{0pt}{accent}
}

\tcbuselibrary{theorems}

\newtcbtheorem[number within=section]{definition}{Определение}{%
    blanker, breakable,
    left=0pt, top=0.2em, bottom=0.2em,
    before skip=0.7em, after skip=0.7em,
    fonttitle=\bfseries, coltitle=primary,
    separator sign={.\ }}{def}

\newtcbtheorem[number within=section]{implementation}{Реализация}{%
    blanker,
    borderline west={1pt}{0pt}{rule},
    left=0.8em, top=0.2em, bottom=0.2em,
    before skip=0.7em, after skip=0.7em,
    fonttitle=\bfseries, coltitle=primary,
    separator sign={.\ }}{impl}

\newtcbtheorem[number within=section]{tcolortheorem}{Теорема}{%
    blanker, breakable,
    left=0pt, top=0.2em, bottom=0.2em,
    before skip=0.7em, after skip=0.7em,
    fonttitle=\bfseries\itshape, coltitle=primary,
    separator sign={.\ }}{tthm}

\newtcbtheorem[number within=section]{algorithm}{Алгоритм}{%
    blanker, breakable,
    borderline west={1pt}{0pt}{rule},
    left=0.8em, top=0.2em, bottom=0.2em,
    before skip=0.7em, after skip=0.7em,
    fonttitle=\bfseries, coltitle=primary,
    separator sign={.\ }}{alg}

